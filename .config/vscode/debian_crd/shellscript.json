{
  // Place your snippets for shellscript here. Each snippet is defined under a snippet name and has a prefix, body and
  // description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
  // $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the
  // same ids are connected.
  // Example:
  // "Print to console": {
  // 	"prefix": "log",
  // 	"body": [
  // 		"console.log('$1');",
  // 		"$2"
  // 	],
  // 	"description": "Log output to console"
  // }
  "Send Discord Notification": {
    "prefix": "senddiscord",
    "body": [
      "send_discord_notification \"$1\""
    ],
    "description": "Send a Discord notification command"
  },
  "Send Discord Notification About GSM Success": {
    "prefix": "senddiscordgsmsuccess",
    "body": [
      "send_discord_notification_about_gsm \"$1作ったよ！\" \"$2したよ！\" \"$3green\""
    ],
    "description": "Send a Discord notification about GSM actions with specific messages"
  },
  "Send Discord Notification About GSM Failure": {
    "prefix": "senddiscordgsmfail",
    "body": [
      "send_discord_notification_about_gsm \"$1失敗…\" \"$2かったよ…\" \"$3red\""
    ],
    "description": "Send a Discord notification about GSM with failure message"
  },
